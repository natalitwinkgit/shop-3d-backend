AI_PROVIDER=gemini
PUBLIC_STORE_URL=
PUBLIC_API_URL=
CLIENT_URL=http://localhost:5173
PASSWORD_RESET_URL=http://localhost:5173/reset-password
# MongoDB connection string for the backend database
# Example: mongodb+srv://<user>:<pass>@cluster0.example.mongodb.net/shop-3d-backend?retryWrites=true&w=majority
MONGO_URI=
# Used by admin AI and automatic i18n key translation
SETTINGS_ENCRYPTION_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
AI_ADMIN_NAME=AI Support
AI_ADMIN_EMAIL=ai-support@shop3d.local
AI_ADMIN_PHONE=
AI_ADMIN_PASSWORD=
SUPERADMIN_NAME=Root Admin
SUPERADMIN_EMAIL=
SUPERADMIN_PHONE=
SUPERADMIN_PASSWORD=
ALLOW_COOKIE_AUTH=false
# Session binding rollout:
# - report: log mismatches, do not block requests
# - enforce: block mismatched/missing fingerprints
# - off: disable fingerprint checks
SESSION_BINDING_MODE=report
# Legacy flag support (kept for backward compatibility)
SESSION_BINDING_ENABLED=false
# Content Security Policy via helmet
CSP_ENABLED=true
# Cloudflare Turnstile for public forms
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_MIN_SCORE=0
# Optional Redis for distributed rate-limit
REDIS_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
LIVE_VOICE_TTS_VOICE=
LIVE_VOICE_LANGUAGE=uk-UA

# Telegram Bot configuration
# Get your token from BotFather (format: 123456:ABCDefGhIJKlmnoPQRstuVwxyz)
TELEGRAM_BOT_TOKEN=
# Enable the Telegram integration (true|false)
TELEGRAM_BOT_ENABLED=false
#
# Cloudinary texture storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Telegram bot microservice
TELEGRAM_SERVICE_PORT=5055
TELEGRAM_SERVICE_INTERNAL_URL=http://localhost:5055/internal
TELEGRAM_MONGO_URI=mongodb://127.0.0.1:27017/shop_3d_telegram
TELEGRAM_BOT_USERNAME=mebli_hub_service_bot
# Must match the key used by telegram-bot-service for /internal routes.
TELEGRAM_INTERNAL_API_KEY=
TELEGRAM_TOKEN_PEPPER=
TELEGRAM_USE_POLLING=true
TELEGRAM_PUBLIC_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
WEBSITE_BASE_URL=http://localhost:5173
WEBSITE_INTERNAL_API_URL=http://localhost:5000/api/internal
# Must match the key sent by telegram-bot-service to the main backend.
WEBSITE_INTERNAL_API_KEY=
TELEGRAM_BIND_CODE_TTL_MINUTES=10
TELEGRAM_LOGIN_TTL_MINUTES=5
TELEGRAM_RECOVERY_TTL_MINUTES=10
TELEGRAM_LOG_LEVEL=info
