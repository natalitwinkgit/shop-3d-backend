NODE_ENV=development

# Service
TELEGRAM_SERVICE_PORT=5055
TELEGRAM_MONGO_URI=mongodb://127.0.0.1:27017/shop_3d_telegram
TELEGRAM_INTERNAL_API_KEY=change-me-long-random-internal-key
TELEGRAM_TOKEN_PEPPER=change-me-long-random-token-pepper
TELEGRAM_LOG_LEVEL=info

# Telegram
TELEGRAM_BOT_TOKEN=123456789:telegram-bot-token
TELEGRAM_BOT_USERNAME=your_shop_bot

# Use webhook in production.
# If this is set, the service registers: {TELEGRAM_PUBLIC_WEBHOOK_URL}/telegram/webhook
TELEGRAM_PUBLIC_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=change-me-telegram-webhook-secret

# Use polling locally if webhook URL is empty.
TELEGRAM_USE_POLLING=true

# Website integration
WEBSITE_BASE_URL=http://localhost:3000
WEBSITE_INTERNAL_API_URL=http://localhost:5000/api/internal
WEBSITE_INTERNAL_API_KEY=change-me-main-backend-internal-key

# TTL
TELEGRAM_BIND_CODE_TTL_MINUTES=10
TELEGRAM_LOGIN_TTL_MINUTES=5
TELEGRAM_RECOVERY_TTL_MINUTES=10
